{
  "name": "marches-boursiers",
  "version": "1.0.0",
  "description": "Analyse fondamentale boursière — CAC 40, S&P 500, DAX",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg --universal",
    "pack": "electron-builder --mac --dir"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.marchesboursiers.app",
    "productName": "Marchés Boursiers",
    "copyright": "Marchés Boursiers — données Yahoo Finance",
    "files": [
      "main.js",
      "server.js",
      "index.html",
      "api/**/*",
      "assets/**/*",
      "!**/.DS_Store",
      "!**/node_modules/.cache"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Marchés Boursiers",
      "backgroundColor": "#F7F4EF",
      "window": { "width": 540, "height": 380 }
    }
  }
}
